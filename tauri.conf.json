{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Autunpad",
  "version": "0.1.0",
  "identifier": "com.autunpad.app",
  "build": {
    "frontendDist": "ui",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Autunpad",
        "width": 1000,
        "height": 660,
        "minWidth": 680,
        "minHeight": 450,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}