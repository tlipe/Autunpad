{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Autunpad",
  "version": "0.1.0",
  "identifier": "com.autunpad.app",
  "build": {
    "frontendDist": "ui",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Autunpad",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis"]
  }
}
